generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

model Availability {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructor_id String     @db.Uuid
  day_of_week   Int
  start_time    DateTime
  end_time      DateTime
  created_at    DateTime   @default(now())
  updated_at    DateTime   @default(now())
  Instructor    Instructor @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId    String     @db.Uuid
  instructorId String     @db.Uuid
  created_at   DateTime   @default(now())
  updated_at   DateTime   @default(now())
  Instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  Student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Message      Message[]

  @@unique([studentId, instructorId])
}

model Credit {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id    String        @db.Uuid
  instructor_id String        @db.Uuid
  balance       Int           @default(0)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @default(now())
  Instructor    Instructor    @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  Student       Student       @relation(fields: [student_id], references: [id], onDelete: Cascade)
  Transaction   Transaction[]

  @@unique([student_id, instructor_id])
}

model Instructor {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String                 @unique @db.Uuid
  rate_per_hour         Decimal?               @db.Money
  stripe_account_id     String?
  created_at            DateTime               @default(now())
  updated_at            DateTime               @default(now())
  Availability          Availability[]
  Conversation          Conversation[]
  Credit                Credit[]
  User                  User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  InstructorProfilePage InstructorProfilePage?
  Lesson                Lesson[]
  Payout                Payout[]
  Review                Review[]
  Student               Student[]
  Subject               Subject[]
}

model InstructorProfilePage {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructor_id   String         @unique @db.Uuid
  bio             String?
  avatar          String?
  cover_media     String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @default(now())
  privacy_setting PrivacySetting @default(PUBLIC)
  Instructor      Instructor     @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
}

model Lesson {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String       @default("Lesson")
  student_id    String       @db.Uuid
  instructor_id String       @db.Uuid
  subject_id    String       @db.Uuid
  video_link    String?
  start_time    DateTime
  end_time      DateTime
  status        LessonStatus @default(PENDING)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @default(now())
  Instructor    Instructor   @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  Student       Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  Subject       Subject      @relation(fields: [subject_id], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  content        String?
  media          String?
  read_at        DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model NotificationSetting {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @unique @db.Uuid
  push_enabled  Boolean  @default(true)
  email_enabled Boolean  @default(true)
  sms_enabled   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())
  User          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Payout {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instructor_id    String       @db.Uuid
  amount           Decimal      @db.Money
  status           PayoutStatus @default(PENDING)
  stripe_payout_id String?
  isDisputed       Boolean      @default(false)
  processed_at     DateTime?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @default(now())
  Instructor       Instructor   @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
}

model Review {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id     String      @db.Uuid
  instructor_id  String      @db.Uuid
  overall_rating Int         @default(0)
  comment        String?
  created_at     DateTime    @default(now())
  Instructor     Instructor  @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  Student        Student     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  SubRating      SubRating[]
}

model Student {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String              @unique @db.Uuid
  created_at         DateTime            @default(now())
  updated_at         DateTime            @default(now())
  Conversation       Conversation[]
  Credit             Credit[]
  Lesson             Lesson[]
  Review             Review[]
  User               User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  StudentProfilePage StudentProfilePage?
  Instructor         Instructor[]
  Subject            Subject[]
}

model StudentProfilePage {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id      String         @unique @db.Uuid
  bio             String?
  avatar          String?
  cover_media     String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @default(now())
  privacy_setting PrivacySetting @default(PUBLIC)
  Student         Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model SubRating {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId String  @db.Uuid
  category String
  rating   Int
  comment  String?
  Review   Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model Subject {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique
  description String?
  Lesson      Lesson[]
  Instructor  Instructor[]
  Student     Student[]
}

model Transaction {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  credit_id         String          @db.Uuid
  money             Decimal         @db.Money
  credits           Int
  type              TransactionType
  stripe_payment_id String?         @unique
  expires_at        DateTime?
  paymentStatus     PaymentStatus   @default(PENDING)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @default(now())
  Credit            Credit          @relation(fields: [credit_id], references: [id], onDelete: Cascade)
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String               @unique
  username            String               @unique @db.Citext
  first_name          String
  last_name           String
  last_active_at      DateTime?
  created_at          DateTime             @default(now())
  updated_at          DateTime             @default(now())
  Instructor          Instructor?
  Message             Message[]
  NotificationSetting NotificationSetting?
  Student             Student?
}

enum LessonStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PrivacySetting {
  PUBLIC
  PRIVATE
}

enum TransactionType {
  CREDIT
  DEBIT
}
